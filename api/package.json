{
  "name": "@chat-logbook/api",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "PORT=3101 CHAT_LOGBOOK_NO_OPEN=1 tsx watch src/index.ts",
    "build": "tsup",
    "test": "vitest run",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:generate:archive": "drizzle-kit generate --config drizzle.archive.config.ts",
    "db:generate:checkpoint": "drizzle-kit generate --config drizzle.checkpoint.config.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "better-sqlite3": "^12.9.0",
    "chokidar": "^5.0.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.7.0",
    "update-notifier": "^7.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "@types/update-notifier": "^6.0.8",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
